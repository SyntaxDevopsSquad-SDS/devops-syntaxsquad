subscription_id      = "00000000-0000-0000-0000-000000000000"
vm_name              = "main-vm"
cloudflare_api_token = "your-cloudflare-api-token"
cloudflare_zone_id   = "your-cloudflare-zone-id"

# DigitalOcean (monitoring VM)
# Opret token på: digitalocean.com → API → Tokens
do_token              = "your-digitalocean-api-token"
# Tilføj ~/.ssh/id_rsa.pub på: digitalocean.com → Settings → Security → SSH Keys
# Kopiér fingerprint herfra:
do_ssh_key_fingerprint = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"